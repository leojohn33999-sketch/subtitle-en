625
01:33:42,017 --> 01:33:45,383
# Buon sia finche' dura l'estate #

626
01:33:45,413 --> 01:33:47,762
# Con canto di uccelli #

627
01:33:48,803 --> 01:33:54,056
# Ma ora si avvicinano il soffio
del vento e il tempo rigido #

628
01:33:55,180 --> 01:33:58,600
# Si', si', si',
questa notte e' lunga #

629
01:33:58,831 --> 01:34:02,603
# E io ingiustamente #

630
01:34:02,633 --> 01:34:05,613
# mi rattristo, piango e digiuno #

