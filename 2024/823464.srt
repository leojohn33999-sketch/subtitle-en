947
00:49:20,869 --> 00:49:22,045
[huffs]

948
00:49:23,742 --> 00:49:25,744
[creature croaking]

949
00:49:25,918 --> 00:49:27,355
[insect squeaking]

950
00:49:30,097 --> 00:49:32,751
[creatures squawking]

951
00:49:42,847 --> 00:49:44,240
[mini-Kong grumbles]

952
00:49:50,507 --> 00:49:52,728
[dramatic music playing]

953
00:50:03,434 --> 00:50:05,045
[sniffing]

954
00:50:08,003 --> 00:50:10,092
[sinister music playing]

955
00:50:13,313 --> 00:50:15,010
