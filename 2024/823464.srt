958
00:50:36,641 --> 00:50:38,512
[Kong groans]

959
00:50:40,471 --> 00:50:41,777
[slurping]

960
00:50:42,952 --> 00:50:44,518
[water rippling]

961
00:50:44,693 --> 00:50:46,521
[sinister music playing]

962
00:50:52,483 --> 00:50:53,483
[Kong grunts]

963
00:50:57,619 --> 00:50:58,706
[growls]

964
00:50:58,880 --> 00:50:59,880
[hissing, snarls]

965
00:51:01,666 --> 00:51:03,494
- [Kong roars]
- [mini-Kong shrieking]

966
00:51:09,195 --> 00:51:10,675
[snarling]

967
00:51:10,849 --> 00:51:12,155
[both grunting]

968
00:51:24,907 --> 00:51:26,300
[Kong roaring]

969
00:51:27,692 --> 00:51:29,215
[roars]

970
00:51:37,789 --> 00:51:39,139
[yelping]

971
00:51:40,530 --> 00:51:42,141
[whines, coughs]

972
00:51:47,407 --> 00:51:48,670
[gasps]

973
00:51:50,237 --> 00:51:52,195
[Kong growling]

974
00:52:01,030 --> 00:52:02,074
[grunts]

975
00:52:03,423 --> 00:52:04,425
[yelps]

976
00:52:07,557 --> 00:52:08,690
[snorts]

977
00:52:17,568 --> 00:52:19,614
[mini-Kong whining]

978
00:52:27,317 --> 00:52:29,362
[groans softly, snorts]

979
00:52:30,581 --> 00:52:31,581
[whimpers]

980
00:52:41,809 --> 00:52:42,809
[Kong grunts]

981
00:52:42,940 --> 00:52:45,074
[growls]

982
00:52:46,117 --> 00:52:47,380
[Kong grunts]

983
00:52:49,686 --> 00:52:51,253
[mini-Kong yelps]

984
00:53:07,443 --> 00:53:10,141
[grunts softly]

985
00:53:11,492 --> 00:53:13,623
[whimpers]

986
00:53:13,797 --> 00:53:15,931
[soft music playing]

987
00:53:31,425 --> 00:53:33,141
